<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.EndfieldOverlay" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Neon green primary -->
        <item name="colorPrimary">#00FF41</item>
        <item name="colorPrimaryVariant">#00CC33</item>
        <item name="colorOnPrimary">#000000</item>

        <item name="colorSecondary">#00CC33</item>
        <item name="colorSecondaryVariant">#009922</item>
        <item name="colorOnSecondary">#000000</item>

        <!-- Pure black background -->
        <item name="android:colorBackground">#000000</item>
        <item name="colorSurface">#0A100A</item>
        <item name="colorOnSurface">#FFFFFF</item>

        <!-- Status / nav bars -->
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Switch thumb / track follow primary -->
        <item name="colorControlActivated">#00FF41</item>
        <item name="colorSwitchThumbNormal">#333333</item>
    </style>
</resources>
