<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ── Title ─────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="30sp"
            android:textColor="#00FF41"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp" />

        <!-- Neon underline bar -->
        <View
            android:layout_width="180dp"
            android:layout_height="1dp"
            android:background="#00FF41"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp" />

        <!-- ── Affinity ──────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tv_affinity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#66FF41"
            android:fontFamily="monospace"
            android:gravity="center"
            android:layout_marginBottom="28dp"
            android:text="@string/affinity_loading" />

        <!-- ── PERMISSIONS section label ─────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_permissions"
            android:textSize="11sp"
            android:textColor="#00FF41"
            android:textAllCaps="true"
            android:fontFamily="monospace"
            android:letterSpacing="0.18"
            android:layout_marginBottom="8dp" />

        <!-- ── Permissions card ──────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_neon"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/perm_overlay"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <Switch
                    android:id="@+id/switch_overlay_perm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1A00FF41" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/perm_notifications"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <Switch
                    android:id="@+id/switch_notif_perm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── CHARACTER MODEL section label ────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_character"
            android:textSize="11sp"
            android:textColor="#00FF41"
            android:textAllCaps="true"
            android:fontFamily="monospace"
            android:letterSpacing="0.18"
            android:layout_marginBottom="8dp" />

        <!-- ── Model status field ────────────────────────────────── -->
        <TextView
            android:id="@+id/tv_char_selected"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/scanning_models"
            android:textColor="#00FF41"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:padding="16dp"
            android:background="@drawable/char_field_neon"
            android:layout_marginBottom="16dp" />

        <!-- ── FILE STRUCTURE section label ─────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_folders"
            android:textSize="11sp"
            android:textColor="#00FF41"
            android:textAllCaps="true"
            android:fontFamily="monospace"
            android:letterSpacing="0.18"
            android:layout_marginBottom="8dp" />

        <!-- ── Folder structure card ─────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_neon"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <!-- Header: base path + copy button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/tv_base_path"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#00FF41"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:text="@string/folder_base" />

                <Button
                    android:id="@+id/btn_copy_path"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="@string/btn_copy"
                    android:textSize="10sp"
                    android:textColor="#000000"
                    android:fontFamily="monospace"
                    android:background="@drawable/btn_neon_secondary"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1A00FF41"
                android:layout_marginBottom="10dp" />

            <!-- Row: Yvonne.pmx -->
            <LinearLayout
                android:id="@+id/row_pmx"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/icon_pmx"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/folder_pmx"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/status_pmx"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_missing"
                    android:textColor="#FF4444"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Row: textures/ -->
            <LinearLayout
                android:id="@+id/row_textures"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/icon_textures"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/folder_textures"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/status_textures"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_missing"
                    android:textColor="#FF4444"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Row: motions/idle/ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/icon_idle"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/folder_idle"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/status_idle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_empty"
                    android:textColor="#FF9900"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Row: motions/poses/ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/icon_poses"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/folder_poses"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/status_poses"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_empty"
                    android:textColor="#FF9900"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Row: motions/waiting/ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/icon_waiting"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/folder_waiting"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/status_waiting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_empty"
                    android:textColor="#FF9900"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Row: motions/dance/ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/icon_dance"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/folder_dance"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/status_dance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_empty"
                    android:textColor="#FF9900"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Row: motions/touch/ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/icon_touch"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/folder_touch"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/status_touch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_empty"
                    android:textColor="#FF9900"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1A00FF41"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <!-- Hint text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/folder_hint"
                android:textColor="#666666"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4" />

        </LinearLayout>

        <!-- ── "Open in Files" button ─────────────────────────────── -->
        <Button
            android:id="@+id/btn_open_folder"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="@string/btn_open_folder"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:fontFamily="monospace"
            android:background="@drawable/btn_neon_secondary"
            android:textColor="#000000"
            android:layout_marginBottom="20dp" />

        <!-- ── START / STOP primary button ──────────────────────── -->
        <Button
            android:id="@+id/btn_start_stop"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_start"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:fontFamily="monospace"
            android:letterSpacing="0.12"
            android:background="@drawable/btn_neon_primary"
            android:textColor="#000000"
            android:layout_marginBottom="12dp" />

        <!-- ── SETTINGS secondary button ─────────────────────────── -->
        <Button
            android:id="@+id/btn_settings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_settings"
            android:textSize="13sp"
            android:textAllCaps="true"
            android:fontFamily="monospace"
            android:letterSpacing="0.12"
            android:background="@drawable/btn_neon_secondary"
            android:textColor="#000000"
            android:layout_marginBottom="24dp" />

        <!-- ── CREATOR link button ────────────────────────────────── -->
        <Button
            android:id="@+id/btn_creator"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/btn_creator"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:fontFamily="monospace"
            android:letterSpacing="0.08"
            android:background="@android:color/transparent"
            android:textColor="#66FF41"
            android:layout_gravity="center_horizontal"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

    </LinearLayout>
</ScrollView>
